# Turso数据库配置
# 从Turso控制台获取: https://turso.tech
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# OpenRouter API配置
# 从OpenRouter获取: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# 默认模型（可选）
OPENROUTER_MODEL=openai/gpt-4o-mini

# JWT认证配置
# 用于签名JWT令牌的密钥，建议使用32位以上的随机字符串
JWT_SECRET=your-jwt-secret-key-at-least-32-chars

# 邀请码配置
# 用于用户注册验证
INVITE_CODE=your-invite-code

# Mem0记忆服务配置（可选）
# 从Mem0获取: https://app.mem0.ai
MEM0_API_KEY=your-mem0-api-key

# SiliconFlow API配置（可选）
# 用于记忆提取功能，从SiliconFlow获取: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your-siliconflow-api-key

# StepFun API配置（可选）
# 用于测试Agent，可自定义API Key
STEPFUN_API_KEY=your-stepfun-api-key

# ==================== 沙盒服务配置 ====================
# 启用沙盒功能
SANDBOX_ENABLED=false

# 沙盒服务地址（HTTPS）
# 示例：https://sandbox.example.com:8443
SANDBOX_GATEWAY_URL=

# API 密钥（与沙盒服务配置一致）
SANDBOX_API_KEY=

# 闲置超时（毫秒，默认30分钟）
SANDBOX_IDLE_TIMEOUT_MS=1800000

# 请求超时（毫秒，默认60秒）
SANDBOX_REQUEST_TIMEOUT_MS=60000

# ==================== Supabase 配置 ====================
# 用于 Skill 文件存储
# 从 Supabase 控制台获取: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your-supabase-project-url

# 公钥（Publishable Key）- 可在客户端使用，受 RLS 策略限制
# 在 Supabase 控制台显示为 "anon public"
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# 密钥（Secret Key）- 只能在服务端使用，绕过 RLS 策略
# 在 Supabase 控制台显示为 "service_role secret"
SUPABASE_SECRET_KEY=your-supabase-secret-key