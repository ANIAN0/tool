# Public browser configuration (publishable key is intentionally public).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Server-only Supabase configuration. Never prefix this value with NEXT_PUBLIC_.
# The server falls back to the two public variables above for its URL and
# publishable key, so only the service-role key is required here.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional server-side aliases when browser and server configuration must be
# kept separate.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Direct OpenAI-compatible provider configuration. No AI Gateway is required.
OPENAI_BASE_URL=https://<provider-endpoint>/v1
OPENAI_API_KEY=<provider-api-key>
EVE_MODEL=<provider-model-id>
# Verify this value against the provider model documentation before production.
EVE_MODEL_CONTEXT_WINDOW_TOKENS=1000000

# Optional second, separately whitelisted model for the selector.
# LONGCAT_FAST_MODEL=<provider-model-id>
# LONGCAT_FAST_CONTEXT_WINDOW_TOKENS=<verified-context-window>

# Langfuse OTel observability. Do not expose either key to the browser.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Chat input and output are captured by default so traces are useful for agent
# debugging. Set this to false only when conversation content must be excluded.
# LANGFUSE_CAPTURE_CONTENT=true

# Before production, enable Supabase Auth Anonymous Sign-Ins. CAPTCHA is optional
# and can be added later if public anonymous traffic shows abuse.
